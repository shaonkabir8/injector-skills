{
  "name": "injector-skills",
  "description": "Ultra-compressed communication mode. Cuts ~75% of tokens while keeping full technical accuracy by speaking like a injector-skills.",
  "author": {
    "name": "Julius Brussee",
    "url": "https://github.com/JuliusBrussee"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/injector-skills-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading injector-skills mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/src/hooks/injector-skills-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking injector-skills mode..."
          }
        ]
      }
    ]
  }
}
